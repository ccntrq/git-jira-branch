{
  "name": "git-jira-branch",
  "version": "2.4.0",
  "description": "Manage branches for your Jira tickets",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ccntrq/git-jira-branch.git"
  },
  "bugs": "https://github.com/ccntrq/git-jira-branch/issues",
  "author": {
    "name": "Alexander 'ccntrq' Pankoff",
    "email": "ccntrq@screenri.de"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "volta": {
    "node": "26.3.0"
  },
  "keywords": [
    "git",
    "jira",
    "productivity"
  ],
  "bin": {
    "git-jira-branch": "dist/main.js",
    "git-jb": "dist/main.js"
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "start": "pnpm build && node dist/main.js",
    "build": "tsc --build src",
    "changeset": "changeset",
    "clean": "rimraf dist/",
    "prepack": "pnpm clean && pnpm build",
    "prepare": "lefthook install",
    "test": "vitest run --exclude=e2e-test",
    "test:watch": "vitest --exclude=e2e-test",
    "test:type-check": "tsc -p src/tsconfig.test.json --noEmit",
    "pretest": "pnpm test:type-check",
    "e2e-test": "pnpm e2e-test:local",
    "e2e-test:local": "pnpm e2e-test:type-check && pnpm build && vitest run --exclude=src",
    "e2e-test:ci": "pnpm e2e-test:type-check && vitest run --exclude=src",
    "e2e-test:type-check": "tsc -p e2e-test/tsconfig.e2e-test.json",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "release": "changeset publish",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@effect/vitest": "0.30.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.19.21",
    "@vitest/ui": "^4.1.9",
    "lefthook": "^2.1.9",
    "rimraf": "^6.1.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@effect/cli": "0.75.2",
    "@effect/platform": "0.96.1",
    "@effect/platform-node": "0.107.0",
    "@effect/printer": "0.49.0",
    "@effect/printer-ansi": "0.49.0",
    "effect": "3.21.3"
  }
}
