{
  "name": "git-jira-branch",
  "version": "2.4.0",
  "description": "Manage branches for your Jira tickets",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ccntrq/git-jira-branch.git"
  },
  "bugs": "https://github.com/ccntrq/git-jira-branch/issues",
  "author": {
    "name": "Alexander 'ccntrq' Pankoff",
    "email": "ccntrq@screenri.de"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "volta": {
    "node": "24.12.0"
  },
  "keywords": [
    "git",
    "jira",
    "productivity"
  ],
  "bin": {
    "git-jira-branch": "dist/main.js",
    "git-jb": "dist/main.js"
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "start": "pnpm build && node dist/main.js",
    "build": "tsc --build src",
    "clean": "rimraf dist/",
    "prepack": "pnpm clean && pnpm build",
    "prepare": "lefthook install",
    "test": "vitest run --exclude=e2e-test",
    "test:watch": "vitest --exclude=e2e-test",
    "test:type-check": "tsc -p src/tsconfig.test.json --noEmit",
    "pretest": "pnpm test:type-check",
    "e2e-test": "pnpm e2e-test:local",
    "e2e-test:local": "pnpm e2e-test:type-check && pnpm build && vitest run --exclude=src",
    "e2e-test:ci": "pnpm e2e-test:type-check && vitest run --exclude=src",
    "e2e-test:type-check": "tsc -p e2e-test/tsconfig.e2e-test.json",
    "lint": "biome check .",
    "lint:fix": "biome check . --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@effect/vitest": "0.29.0",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^25.5.0",
    "@vitest/ui": "^4.1.1",
    "lefthook": "^2.1.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@effect/cli": "0.73.2",
    "@effect/platform": "0.94.5",
    "@effect/platform-node": "0.104.1",
    "@effect/printer": "0.47.0",
    "@effect/printer-ansi": "0.47.0",
    "effect": "3.20.0"
  }
}
